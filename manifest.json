{
  "manifest_version": 3,
  "name": "ApplySure",
  "version": "1.0.1",
  "description": "Analyze your resume vs LinkedIn & Naukri jobs. Get ATS score, skill gaps, and a tailored job-ready resume in seconds.",
  "icons": {
    "16": "assets/image-16x16.png",
    "32": "assets/image-32x32.png",
    "48": "assets/image-48x48.png",
    "128": "assets/image-128x128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://applysure.vercel.app/*",
    "*://*.linkedin.com/*",
    "*://*.naukri.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ApplySure",
    "default_icon": {
      "16": "assets/image-16x16.png",
      "32": "assets/image-32x32.png",
      "48": "assets/image-48x48.png",
      "128": "assets/image-128x128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.naukri.com/*"
      ],
      "js": [
        "naukri.js",
        "content.js"
      ]
    }
  ]
}