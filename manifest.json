{
  "manifest_version": 3,
  "name": "ApplySure",
  "version": "2.0",
  "description": "Instantly analyze how well your resume matches any LinkedIn or Naukri job — get ATS score, skill gaps, and a tailored job-ready resume in one click.",
  "icons": {
    "16": "assets/image-16x16.png",
    "32": "assets/image-32x32.png",
    "48": "assets/image-48x48.png",
    "128": "assets/image-128x128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.mistral.ai/*",
    "https://api.openai.com/*",
    "https://api.groq.com/*",
    "https://applysure.vercel.app/*",
    "*://*.linkedin.com/*",
    "*://*.naukri.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ApplySure",
    "default_icon": {
      "16": "assets/image-16x16.png",
      "32": "assets/image-32x32.png",
      "48": "assets/image-48x48.png",
      "128": "assets/image-128x128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.naukri.com/*"
      ],
      "js": [
        "html2pdf.bundle.min.js",
        "naukri.js",
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pdf.min.js",
        "pdf.worker.min.js"
      ],
      "matches": [
        "*://*/*"
      ]
    }
  ]
}